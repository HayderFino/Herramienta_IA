# admin/.htaccess
# Bloquear acceso directo a archivos sensibles
Options -Indexes

<FilesMatch "\.(json|txt|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
